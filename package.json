{
  "name": "uslugpol-recruitment-task",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate --filter=@uslugpol/core --filter=@uslugpol/event-service --filter=@uslugpol/car-service",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@uslugpol/core --filter=@uslugpol/event-service --filter=@uslugpol/car-service",
    "db:generate": "turbo run db:generate --filter=@uslugpol/core --filter=@uslugpol/event-service --filter=@uslugpol/car-service",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@prisma/adapter-pg": "^7.4.0",
    "husky": "^9.1.7",
    "pg": "^8.18.0",
    "prettier": "^3.7.4",
    "prisma": "^7.4.0",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
